<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox spacing="15" prefWidth="220" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="30" left="15" right="15"/>
            </padding>

            <Text text="EVENTIFY" style="-fx-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Separator opacity="0.3"/>

            <Button fx:id="btnExplorar" text="Explorar Eventos" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>

            <Button fx:id="btnMisCompras" text="Mis Compras" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>

            <Button fx:id="btnPerfil" text="Mi Perfil" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>

            <Button fx:id="btnReportes" text="Reportes (CSV/PDF)" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS" /> <Button fx:id="btnCerrarSesion" text="🚪 Cerrar Sesión" maxWidth="Infinity"
                                                   style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-margin-bottom: 20;"/>
            <padding>
                <Insets bottom="20"/>
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" left="30" right="30" bottom="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Text fx:id="txtBienvenida" text="Bienvenido, Usuario" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            </HBox>

            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;">
                <children>
                    <Label text="Selecciona una opción del menú para comenzar" textFill="#7f8c8d" />
                </children>
            </StackPane>
        </VBox>
    </center>
</BorderPane>