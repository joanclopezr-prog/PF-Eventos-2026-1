<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox prefWidth="250" spacing="10" style="-fx-background-color: #1a252f;">
            <padding>
                <Insets bottom="20" left="15" right="15" top="20" />
            </padding>

            <VBox alignment="CENTER" spacing="10">
                <Text style="-fx-fill: #3498db; -fx-font-size: 18; -fx-font-weight: bold;" text="ADMIN PANEL" />
                <Text style="-fx-fill: #bdc3c7; -fx-font-size: 12;" text="Operaciones Eventify" />
                <Separator opacity="0.2" prefWidth="200" />
            </VBox>

            <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="GESTIÓN DE CATÁLOGO" textFill="#7f8c8d">
                <padding><Insets top="15" /></padding>
            </Label>

            <Button fx:id="btnGestionEventos" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-cursor: hand;" text="Eventos" />

            <Button fx:id="btnGestionRecintos" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-cursor: hand;" text="Recintos y Zonas" />

            <Button fx:id="btnGestionAsientos" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-cursor: hand;" text="Asientos" />

            <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="OPERACIONES" textFill="#7f8c8d">
                <padding><Insets top="15" /></padding>
            </Label>

            <Button fx:id="btnGestionUsuarios" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-cursor: hand;" text="Usuarios" />

            <Button fx:id="btnControlCompras" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-cursor: hand;" text="Ventas" />

            <Button fx:id="btnIncidencias" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-cursor: hand;" text="Incidencias" />

            <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="ANALÍTICA" textFill="#7f8c8d">
                <padding><Insets top="15" /></padding>
            </Label>

            <Button fx:id="btnMetricas" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-background-radius: 5;" text="📈 Panel de Métricas" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnCerrarSesionAdmin" maxWidth="Infinity" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Cerrar Sesión" />
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_RIGHT" prefHeight="60" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                <padding><Insets right="30" /></padding>
                <HBox alignment="CENTER" spacing="15">
                    <VBox alignment="CENTER_RIGHT">
                        <Text style="-fx-font-weight: bold;" text="Admin Master" />
                        <Text style="-fx-font-size: 10; -fx-fill: #7f8c8d;" text="Modo Dios" />
                    </VBox>
                    <Circle fill="#3498db" radius="18" />
                </HBox>
            </HBox>

            <StackPane fx:id="contentAreaAdmin" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="25" left="25" right="25" top="25" />
                </padding>
                <VBox alignment="CENTER" spacing="10">
                    <Text style="-fx-font-size: 20; -fx-fill: #95a5a6;" text="Panel de Control Principal" />
                    <Text style="-fx-fill: #bdc3c7;" text="Seleccione una categoría a la izquierda para gestionar el sistema." />
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
