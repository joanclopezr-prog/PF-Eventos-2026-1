<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" fx:controller="org.example.pfeventos20261.viewController.administrador.GestionRecintoViewController" style="-fx-background-color: white; -fx-background-radius: 10;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <VBox spacing="5">
        <Text style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: #2c3e50;" text="Gestión de Recintos" />
        <Text style="-fx-fill: #7f8c8d;" text="Administra los lugares físicos y sus configuraciones espaciales." />
    </VBox>

    <Separator />

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <VBox prefWidth="300" spacing="15" style="-fx-background-color: #fcfcfc; -fx-padding: 15; -fx-border-color: #eee; -fx-border-radius: 5;">
            <Text style="-fx-font-weight: bold; -fx-fill: #34495e;" text="Datos del Recinto" />

            <VBox spacing="5">
                <Label style="-fx-font-size: 11;" text="Nombre del Lugar" />
                <TextField fx:id="txtNombreRecinto" promptText="Ej: Teatro Nacional" style="-fx-pref-height: 35;" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-size: 11;" text="Dirección" />
                <TextField fx:id="txtDireccionRecinto" promptText="Ej: Calle 10 # 5-20" style="-fx-pref-height: 35;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnGuardarRecinto" maxWidth="Infinity" onAction="#onAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 40;" text="Guardar / Actualizar" />

            <Button fx:id="btnEditarRecinto" maxWidth="Infinity" onAction="#onEditar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 40;" text="editar recinto" />

            <Button fx:id="btnLimpiarForm" maxWidth="Infinity" onAction="#onLimpiar" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 3;" text="Limpiar Campos" />
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS">

            <TableView fx:id="tblRecintos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="80" text="ID" />
                    <TableColumn fx:id="colNombre" prefWidth="200" text="Nombre" />
                    <TableColumn fx:id="colDireccion" prefWidth="250" text="Dirección" />
                    <TableColumn fx:id="colZonas" prefWidth="80" text="N° Zonas" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 10 0 0 0;">
                <Button fx:id="btnEliminarRecinto" onAction="#onEliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Eliminar" />

                <Separator orientation="VERTICAL" />

                <Button fx:id="btnConfigurarMapa" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="⚙️ Configurar Zonas y Asientos" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
