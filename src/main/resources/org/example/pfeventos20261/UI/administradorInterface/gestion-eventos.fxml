<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-background-color: white; -fx-background-radius: 10;">

    <padding>
        <Insets top="20" left="20" right="20" bottom="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Text text="Administración de Eventos" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>
            <Text text="Crea, edita y gestiona el ciclo de vida de tus eventos." style="-fx-fill: #7f8c8d;"/>
        </VBox>
        <Button fx:id="btnNuevoEvento" text="+ Nuevo Evento"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>

    <Separator />

    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-background-radius: 5;">
        <TextField fx:id="txtBuscarEvento" promptText="Buscar por nombre o ciudad..." prefWidth="300" style="-fx-pref-height: 35;"/>

        <ComboBox fx:id="cbFiltroCategoria" promptText="Categoría" prefWidth="150" style="-fx-pref-height: 35;"/>

        <ComboBox fx:id="cbFiltroEstado" promptText="Estado" prefWidth="150" style="-fx-pref-height: 35;"/>

        <Button fx:id="btnLimpiarFiltros" text="Limpiar" style="-fx-pref-height: 35;"/>
    </HBox>

    <TableView fx:id="tblEventos" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colNombre" text="Evento" prefWidth="200" />
            <TableColumn fx:id="colFecha" text="Fecha y Hora" prefWidth="150" />
            <TableColumn fx:id="colLugar" text="Recinto / Ciudad" prefWidth="180" />
            <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Label text="Acciones para el evento seleccionado:" style="-fx-font-style: italic; -fx-text-fill: #7f8c8d;">
            <padding><Insets right="10"/></padding>
        </Label>

        <Button fx:id="btnEditar" text="Editar" style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>

        <Separator orientation="VERTICAL" />

        <Button fx:id="btnPublicar" text="Publicar" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button fx:id="btnPausar" text="Pausar" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
        <Button fx:id="btnCancelar" text="Cancelar Evento" style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
    </HBox>

</VBox>