<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="700.0" prefWidth="1100.0" spacing="0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pfeventos20261.viewController.administrador.GestionAsientosViewController">

    <VBox prefWidth="350" spacing="15" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Text style="-fx-font-size: 18; -fx-font-weight: bold;" text="Configurador de Recinto" />
        <Separator />

        <Label style="-fx-font-weight: bold;" text="1. Seleccionar Recinto" />
        <ComboBox fx:id="cbRecintoDestino" maxWidth="Infinity" promptText="Seleccione recinto..." style="-fx-pref-height: 35;" />

        <TabPane fx:id="tabPaneEditor" style="-fx-border-color: #ddd;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Añadir Zona">
                    <VBox spacing="10" style="-fx-padding: 15;">
                        <TextField fx:id="txtIdZona" promptText="ID Zona (Ej: Z-VIP)" />
                        <TextField fx:id="txtNombreZona" promptText="Nombre (Ej: VIP Norte)" />
                        <ComboBox fx:id="cbTipoZona" maxWidth="Infinity" promptText="Tipo de Zona" />
                        <TextField fx:id="txtPrecioBase" promptText="Precio Base ($)" />
                        <HBox spacing="10">
                            <TextField fx:id="txtZonaX" prefWidth="80" promptText="Pos X" />
                            <TextField fx:id="txtZonaY" prefWidth="80" promptText="Pos Y" />
                        </HBox>
                        <Button fx:id="btnGuardarZona" maxWidth="Infinity" onAction="#onGuardarZona" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Registrar Zona" />
                  <Button fx:id="btnGuardarZona1" layoutX="25.0" layoutY="205.0" maxWidth="Infinity" onAction="#onEditarZona" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="editar" />
                  <Button fx:id="btnGuardarZona11" layoutX="25.0" layoutY="241.0" maxWidth="Infinity" onAction="#onEliminarZona" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="eliminar" />
                    </VBox>
                </Tab>

                <Tab text="Añadir Asientos">
                    <VBox spacing="10" style="-fx-padding: 15;">
                        <Label style="-fx-font-size: 11;" text="Zona seleccionada:" />
                        <Label fx:id="lblZonaActual" style="-fx-text-fill: #e67e22; -fx-font-weight: bold;" text="Ninguna" />

                        <Separator />

                        <TextField fx:id="txtNumeroAsiento" promptText="Número de Asiento" />
                        <HBox spacing="10">
                            <TextField fx:id="txtAsientoX" prefWidth="80" promptText="Pos X" />
                            <TextField fx:id="txtAsientoY" prefWidth="80" promptText="Pos Y" />
                        </HBox>
                        <ComboBox fx:id="cbAsientoTipo" maxWidth="Infinity" promptText="Seleccione el estado del asiento" style="-fx-pref-height: 35;" />
                        <Button fx:id="btnGuardarAsiento" maxWidth="Infinity" onAction="#onGuardarAsiento" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Agregar Asiento" />
                  <Button fx:id="btnGuardarAsiento1" layoutX="25.0" layoutY="211.0" maxWidth="Infinity" onAction="#onEditarAsiento" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Editar" />
                  <Button fx:id="btnGuardarAsiento11" layoutX="25.0" layoutY="272.0" maxWidth="Infinity" onAction="#onEliminarAsiento" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Eliminar" />
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="15" left="15" right="15" top="15" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="20">
            <Text style="-fx-font-size: 16; -fx-font-weight: bold;" text="Vista Previa del Mapa" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #95a5a6;" text="Escala: 1px = 1 unidad" />
        </HBox>

        <ScrollPane hbarPolicy="NEVER" style="-fx-background: #bdc3c7; -fx-border-color: #7f8c8d;" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
            <content>
                <GridPane fx:id="gridRecinto" hgap="4" vgap="4" />
            </content>
        </ScrollPane>

        <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5;">
            <Label style="-fx-font-weight: bold;" text="Leyenda:" />
            <HBox alignment="CENTER" spacing="5"><Region style="-fx-background-color: #3498db; -fx-pref-width: 15; -fx-pref-height: 15;" /><Label text="Zona" /></HBox>
            <HBox alignment="CENTER" spacing="5"><Region style="-fx-background-color: #2ecc71; -fx-pref-width: 15; -fx-pref-height: 15; -fx-shape: 'M 10 20 A 10 10 0 1 1 10.001 20 Z';" /><Label text="Asiento Disponible" /></HBox>
        </HBox>
    </VBox>
</HBox>
