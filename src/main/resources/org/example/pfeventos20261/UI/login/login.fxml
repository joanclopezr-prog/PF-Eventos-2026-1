<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" prefWidth="400" prefHeight="500"
      style="-fx-background-color: #f4f4f4;"
      fx:controller="org.example.pfeventos20261.viewController.loggin.logginViewController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="10" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

        <Text text="Eventify Login" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>

        <Separator prefWidth="200.0" />

        <Label text="Correo Electrónico" maxWidth="Infinity"/>
        <TextField fx:id="txtCorreo" promptText="ejemplo@correo.com" style="-fx-pref-height: 35;"/>

        <Label text="Contraseña" maxWidth="Infinity"/>
        <PasswordField fx:id="txtPassword" promptText="••••••••" style="-fx-pref-height: 35;"/>

        <Button fx:id="btnLogin" text="Iniciar Sesión" maxWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 40; -fx-cursor: hand;"/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="¿No tienes cuenta?" />
            <Hyperlink fx:id="linkRegistro" text="Regístrate aquí" />
        </HBox>
    </VBox>
</VBox>